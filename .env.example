# ===== Database =====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/memorystory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=memorystory
DB_PORT=5432

# ===== JWT =====
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===== Bcrypt =====
BCRYPT_SALT_ROUNDS=12

# ===== Server =====
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
