# ===== Database =====
# 本地开发：localhost，Docker 部署：postgres（服务名）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/memorystory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=memorystory
DB_PORT=5432

# ===== JWT =====
# ⚠️ 生产环境必须替换为强随机字符串（openssl rand -base64 64）
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===== Bcrypt =====
BCRYPT_SALT_ROUNDS=12

# ===== Server =====
PORT=3001
HOST=0.0.0.0
# 本地开发：http://localhost:5173，Docker 部署：http://localhost
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# ===== Docker =====
# 前端对外端口（docker compose up 后访问 http://localhost:8080）
FRONTEND_PORT=8080
